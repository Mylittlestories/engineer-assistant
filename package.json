{
  "name": "engineer-assistant",
  "private": true,
  "version": "1.2.1",
  "type": "module",
  "main": "electron/main.cjs",
  "bin": "dist/server.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:desktop": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --external:vite --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "electron:dev": "npm run build && electron electron/main.cjs",
    "dist:win": "npm run build && electron-builder --win nsis portable --publish never",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb --publish never",
    "dist:mac": "npm run build && electron-builder --mac dmg --publish never",
    "pwa:build": "npm run build",
    "android:add": "cap add android",
    "android:sync": "npm run build && cap sync android",
    "android:open": "cap open android",
    "android:build:debug": "npm run android:sync && cd android && ./gradlew assembleDebug",
    "android:build:release": "npm run android:sync && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "vite": "^6.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.7",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "allowScripts": {
    "@google/genai@2.7.0": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.0": true,
    "protobufjs@7.6.2": true
  },
  "productName": "Engineer Assistant",
  "description": "Professional desktop AI assistant for marine engineering troubleshooting, calculations, and offline knowledge.",
  "author": {
    "name": "Mylittlestories",
    "email": "noreply@example.com"
  },
  "build": {
    "appId": "com.mylittlestories.engineerassistant",
    "productName": "Engineer Assistant",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "Engineer-Assistant-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "Engineer-Assistant-Setup-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Education",
      "maintainer": "Mylittlestories <noreply@example.com>",
      "artifactName": "Engineer-Assistant-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.education",
      "artifactName": "Engineer-Assistant-${version}-${arch}.${ext}"
    }
  }
}
